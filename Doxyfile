# --- Project Info ---
PROJECT_NAME           = "DAG"
PROJECT_NUMBER         = 1.0
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES

# --- Input Configuration ---
INPUT                  = . 
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.hpp *.h *.md
EXCLUDE                = docs/

# --- Extraction Settings ---
# These are vital for documenting your private methods like HasCycle
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_PACKAGE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO

# --- Path Handling ---
# This makes the documentation look cleaner by removing local paths
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = /home/marek/Coding/DAG/
STRIP_FROM_INC_PATH    = /home/marek/Coding/DAG/src/

# --- Warning & Error Logging ---
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_LOGFILE           = doxygen_warnings.log

# --- HTML Output Settings ---
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
GENERATE_TREEVIEW      = YES 
SEARCHENGINE           = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

# --- LaTeX / PDF ---
GENERATE_LATEX         = NO

# --- Diagrams (Graphviz/Dot) ---
# Set HAVE_DOT to NO if you do not have Graphviz installed 
# to avoid "Exit Code 127" errors.
HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
DOT_FONTNAME           = Helvetica
DOT_FONTSIZE           = 10
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
TEMPLATE_RELATIONS     = NO
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = NO
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES
DOT_IMAGE_FORMAT       = png
INTERACTIVE_SVG        = NO
DOT_GRAPH_MAX_NODES    = 50
MAX_DOT_GRAPH_DEPTH    = 0
DOT_TRANSPARENT        = NO
DOT_MULTI_TARGETS      = NO
GENERATE_LEGEND        = YES
DOT_CLEANUP            = YES

# --- Optimization ---
OPTIMIZE_OUTPUT_FOR_C  = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES